{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "typeRoots": [
      "../synth-data/node_modules/@types",
      "../synth-data/node_modules"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts", "ui/src/**/*.ts", "ui/src/**/*.tsx", "shared/**/*.ts"]
}
