{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "types": ["bun-types"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".."
  },
  "include": ["steps/**/*.ts", "scripts/**/*.ts", "templates/**/*.ts", "../shared/**/*.ts"]
}
